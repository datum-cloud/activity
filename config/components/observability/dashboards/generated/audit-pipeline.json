         "id": 11,
         "options": {
            "colorMode": "background",
            "graphMode": "area",
            "reduceOptions": {
               "calcs": [
                  "lastNotNull"
               ]
            }
         },
         "pluginVersion": "v11.4.0",
         "targets": [
