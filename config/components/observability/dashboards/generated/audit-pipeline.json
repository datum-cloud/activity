               },
               "expr": "sum(rate(apiserver_audit_level_total{job=~\".*apiserver.*\"}[5m])) by (level)",
               "legendFormat": "{{level}}"
            }
         ],
         "title": "Audit Policy Levels",
         "type": "timeseries"
      },
      {
