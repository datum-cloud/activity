            "reduceOptions": {
               "calcs": [
                  "lastNotNull"
               ]
            },
            "textMode": "value_and_name"
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "min(up{job=~\"vector|nats-system/nats|clickhouse-activity-clickhouse|activity-apiserver\",namespace=~\"activity-system|nats-system\"})",
               "legendFormat": "Status"
            }
         ],
         "title": "Component Health",
         "type": "stat"
      },
