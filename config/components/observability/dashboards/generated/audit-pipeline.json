            }
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "histogram_quantile(0.99, sum(rate(vector_source_lag_time_seconds_bucket{component_id=\"nats_consumer\"}[5m])) by (le)) + (rate(chi_clickhouse_event_InsertQueryTimeMicroseconds{chi=\"activity-clickhouse\"}[5m]) / rate(chi_clickhouse_event_InsertQuery{chi=\"activity-clickhouse\"}[5m]) / 1000000)",
               "legendFormat": "p99"
            }
         ],
         "title": "End-to-End Latency (p99)",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "All pipeline components UP",
         "fieldConfig": {
            "defaults": {
               "mappings": [
                  {
                     "options": {
                        "0": {
                           "color": "red",
                           "text": "DOWN"
                        }
                     },
                     "type": "value"
                  },
                  {
                     "options": {
                        "1": {
                           "color": "green",
                           "text": "ALL UP"
                        }
                     },
                     "type": "value"
                  }
               ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": null
                     },
                     {
                        "color": "green",
                        "value": 1
                     }
                  ]
               }
