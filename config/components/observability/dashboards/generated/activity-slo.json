      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Error budget remaining for Metadata API at 99% SLO target. Calculated over a 5m window. 100%% = no budget consumed, 0%% = fully exhausted.",
         "fieldConfig": {
            "defaults": {
               "decimals": 1,
               "mappings": [
                  {
                     "options": {
                        "match": "null",
                        "result": {
                           "color": "text",
                           "text": "No traffic"
                        }
                     },
                     "type": "special"
                  }
               ],
               "max": 100,
               "min": 0,
               "noValue": "No traffic",
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": null
                     },
                     {
                        "color": "yellow",
                        "value": 10
                     },
                     {
                        "color": "green",
                        "value": 25
                     }
                  ]
               },
               "unit": "percent"
            }
         },
         "gridPos": {
            "h": 7,
            "w": 6,
            "x": 0,
            "y": 8
         },
         "id": 8,
         "options": {
            "orientation": "auto",
            "reduceOptions": {
