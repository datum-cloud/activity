                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "(clamp_min((activity:slo_metadata:request_good:rate5m / activity:slo_metadata:request_total:rate5m - 0.99) / (1 - 0.99), 0) * 100) and activity:slo_metadata:request_total:rate5m > 0",
