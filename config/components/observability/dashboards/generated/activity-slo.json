{
   "description": "SLO tracking for the Activity API Server: success ratios, error budget consumption, multi-window burn rates, and latency percentiles against defined SLO targets.",
   "editable": true,
   "graphTooltip": 1,
   "panels": [
      {
         "collapsed": false,
         "gridPos": {
            "h": 1,
            "w": 24,
            "x": 0,
            "y": 0
         },
         "id": 1,
         "title": "SLO Status (5m window)",
         "type": "row"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Current success ratio for Metadata API (good requests / total requests, 5m window). Target: >99.0%",
         "fieldConfig": {
            "defaults": {
               "color": {
                  "fixedColor": "text"
               },
               "decimals": 3,
               "mappings": [
                  {
                     "options": {
                        "match": "null",
                        "result": {
                           "color": "text",
                           "text": "No traffic"
                        }
                     },
                     "type": "special"
                  }
               ],
               "noValue": "No traffic",
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": null
                     },
                     {
                        "color": "yellow",
                        "value": 0.98999999999999999
                     },
                     {
                        "color": "green",
                        "value": 0.999
                     }
                  ]
               },
               "unit": "percentunit"
            }
         },
         "gridPos": {
            "h": 6,
            "w": 6,
            "x": 0,
            "y": 1
         },
         "id": 2,
         "options": {
            "colorMode": "background",
            "graphMode": "area",
            "reduceOptions": {
               "calcs": [
                  "lastNotNull"
               ]
            },
            "textMode": "value_and_name"
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "(activity:slo_metadata:request_good:rate5m / activity:slo_metadata:request_total:rate5m) and activity:slo_metadata:request_total:rate5m > 0",
               "legendFormat": "Metadata API"
            }
         ],
         "title": "Metadata API",
         "type": "stat"
