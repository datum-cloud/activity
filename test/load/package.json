{
  "name": "activity-load-tests",
  "version": "1.0.0",
  "description": "k6 load tests for Activity query endpoints",
  "type": "module",
  "scripts": {
    "test": "npm run build && npm run test:k6",
    "build": "webpack",
    "test:k6": "k6 run dist/query-load-test.js",
    "test:k6:steady": "k6 run --include-system-env-vars --env SCENARIO=steady_load dist/query-load-test.js",
    "test:k6:ramp": "k6 run --include-system-env-vars --env SCENARIO=ramp_up dist/query-load-test.js",
    "test:k6:spike": "k6 run --include-system-env-vars --env SCENARIO=spike dist/query-load-test.js",
    "test:k6:cloud": "k6 cloud dist/query-load-test.js",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/k6": "^0.52.0",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1"
  },
  "keywords": [
    "k6",
    "load-test",
    "performance",
    "kubernetes",
    "audit-logs"
  ],
  "author": "",
  "license": "Apache-2.0"
}
